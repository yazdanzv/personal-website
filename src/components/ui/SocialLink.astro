---
import { icons } from '../../lib/icons';

interface Props {
  href: string;
  label: string;
  icon: keyof typeof icons;
  class?: string;
}

const { href, label, icon, class: className = '' } = Astro.props as Props;
const external = href.startsWith('http') || href.startsWith('mailto:');
---

<a
  href={href}
  class={`inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm font-medium text-ink-200 transition duration-300 hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/[0.08] hover:text-white ${className}`}
  target={external && !href.startsWith('mailto:') ? '_blank' : undefined}
  rel={external && !href.startsWith('mailto:') ? 'noreferrer noopener' : undefined}
>
  <span class="size-4 shrink-0 text-current" set:html={icons[icon]}></span>
  <span>{label}</span>
</a>
