---
import type { SkillGroup as SkillGroupType } from '../../config/profile';
import { toneStyles } from '../../lib/tone';

interface Props {
  group: SkillGroupType;
  delay?: number;
}

const { group, delay = 0 } = Astro.props as Props;
const accent = toneStyles[group.tone];
---

<div
  class="glass-panel rounded-3xl p-6 transition duration-300 hover:-translate-y-1 hover:border-white/20 hover:bg-white/[0.08]"
  data-reveal
  style={`--reveal-delay:${delay}ms`}
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-xs uppercase tracking-[0.34em] text-ink-400">Skill group</p>
      <h3 class={`mt-3 font-display text-2xl font-semibold ${accent.text}`}>{group.title}</h3>
    </div>
    <span class={`h-3 w-3 rounded-full ${accent.orb} ${accent.glow}`}></span>
  </div>

  <div class="mt-6 flex flex-wrap gap-2">
    {group.items.map((item) => (
      <span class={`rounded-full border px-3 py-1 text-sm ${accent.pill}`}>
        {item}
      </span>
    ))}
  </div>
</div>
