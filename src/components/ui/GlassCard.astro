---
import type { AccentTone } from '../../config/profile';
import { toneStyles } from '../../lib/tone';

interface Props {
  as?: string;
  tone?: AccentTone;
  class?: string;
  delay?: number;
  interactive?: boolean;
}

const {
  as: Tag = 'div',
  tone = 'cyan',
  class: className = '',
  delay = 0,
  interactive = true,
} = Astro.props as Props;

const accent = toneStyles[tone];
---

<Tag
  class={`group relative overflow-hidden rounded-3xl border border-white/10 bg-white/[0.05] p-6 shadow-[0_24px_80px_rgba(0,0,0,0.32)] backdrop-blur-xl transition duration-300 ${
    interactive ? 'hover:-translate-y-1 hover:border-white/20 hover:bg-white/[0.08]' : ''
  } ${className}`}
  data-reveal
  style={`--reveal-delay:${delay}ms`}
>
  <div
    aria-hidden="true"
    class={`pointer-events-none absolute inset-0 bg-gradient-to-br ${accent.line} opacity-0 blur-2xl transition duration-300 group-hover:opacity-100`}
  ></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.09),transparent_38%)] opacity-0 transition duration-300 group-hover:opacity-100"
  ></div>
  <div class="relative z-10">
    <slot />
  </div>
</Tag>
