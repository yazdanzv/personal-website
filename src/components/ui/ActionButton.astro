---
import { icons } from '../../lib/icons';

interface Props {
  href: string;
  label: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  icon?: keyof typeof icons;
  external?: boolean;
  download?: boolean;
  class?: string;
}

const {
  href,
  label,
  variant = 'primary',
  icon = 'arrow',
  external = false,
  download = false,
  class: className = '',
} = Astro.props as Props;

const variants = {
  primary:
    'bg-gradient-to-r from-accent-400 via-cyan-400 to-violet-400 text-surface-950 shadow-[0_18px_42px_rgba(56,189,248,0.24)] hover:shadow-[0_22px_54px_rgba(56,189,248,0.32)]',
  secondary:
    'border border-white/[0.12] bg-white/5 text-ink-100 hover:border-white/20 hover:bg-white/10',
  ghost:
    'border border-transparent bg-transparent text-ink-300 hover:border-white/[0.12] hover:bg-white/5 hover:text-ink-100',
};
---

<a
  href={href}
  class={`inline-flex items-center justify-center gap-2 rounded-full px-5 py-3 text-sm font-semibold transition duration-300 ${variants[variant]} ${className}`}
  target={external ? '_blank' : undefined}
  rel={external ? 'noreferrer noopener' : undefined}
  download={download ? 'Yazdan-Zandiye-Vakili-CV.pdf' : undefined}
>
  <span class="size-4 shrink-0 text-current" set:html={icons[icon]}></span>
  <span>{label}</span>
</a>
