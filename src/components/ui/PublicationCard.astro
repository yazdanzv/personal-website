---
import type { PublicationEntry } from '../../config/profile';
import { icons } from '../../lib/icons';
import { toneStyles } from '../../lib/tone';

interface Props {
  publication: PublicationEntry;
  delay?: number;
}

const { publication, delay = 0 } = Astro.props as Props;
const accent = toneStyles[publication.tone];
---

<article
  class="group relative flex h-full flex-col overflow-hidden rounded-3xl border border-white/10 bg-white/[0.05] p-6 shadow-[0_24px_80px_rgba(0,0,0,0.32)] backdrop-blur-xl transition duration-300 hover:-translate-y-1 hover:border-white/20 hover:bg-white/[0.08]"
  data-reveal
  style={`--reveal-delay:${delay}ms`}
>
  <div
    aria-hidden="true"
    class={`pointer-events-none absolute inset-0 bg-gradient-to-br ${accent.line} opacity-0 blur-2xl transition duration-300 group-hover:opacity-100`}
  ></div>

  <div class="relative z-10 flex h-full flex-col">
    <div class="flex items-start justify-between gap-4">
      <div class="max-w-[80%]">
        <p class="text-xs uppercase tracking-[0.34em] text-ink-400">{publication.area}</p>
        <h3 class="mt-3 font-display text-2xl font-semibold text-ink-100">{publication.title}</h3>
      </div>
      <span class={`shrink-0 rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.28em] ${accent.pill}`}>
        {publication.indicator}
      </span>
    </div>

    <p class="mt-5 text-sm leading-7 text-ink-300">{publication.summary}</p>

    <div class="mt-6 flex flex-wrap gap-2">
      {publication.tags.map((tag) => (
        <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs text-ink-300">
          {tag}
        </span>
      ))}
    </div>

    {publication.citationCount > 0 ? (
      <div class="mt-5 flex items-center justify-between gap-3">
        <span class="text-xs uppercase tracking-[0.3em] text-ink-400">Citations</span>
        <span class={`rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs font-semibold text-ink-200 ${publication.ctaLabel ? 'opacity-70' : ''}`}>
          {publication.citationCount.toLocaleString()} citation{publication.citationCount === 1 ? '' : 's'}
        </span>
      </div>
    ) : null}

    {publication.ctaLabel ? (
      <div class="mt-auto pt-6">
        <span
          class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm font-semibold text-ink-300 opacity-85"
          aria-disabled="true"
        >
          <span class="size-4 shrink-0 text-current" set:html={icons.spark}></span>
          <span>{publication.ctaLabel}</span>
        </span>
      </div>
    ) : publication.url ? (
      <div class="mt-auto pt-6">
        <a
          href={publication.url}
          class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm font-semibold text-ink-100 transition duration-300 hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/[0.08]"
          target="_blank"
          rel="noreferrer noopener"
        >
          <span class="size-4 shrink-0 text-current" set:html={icons.external}></span>
          <span>Open paper</span>
        </a>
      </div>
    ) : null}
  </div>
</article>
