---
import { profile } from '../../config/profile';
import SectionShell from '../ui/SectionShell.astro';
import GlassCard from '../ui/GlassCard.astro';
import { icons } from '../../lib/icons';
import { toneStyles } from '../../lib/tone';

const resolveAssetUrl = (href: string) => (href.startsWith('http') ? href : `${import.meta.env.BASE_URL ?? '/'}${href.replace(/^\/+/, '')}`);
---

<SectionShell
  id="languages"
  eyebrow="Languages"
  title="Communication"
  description="Languages I use in academic, engineering, and collaborative settings."
  tone="cyan"
>
  <div class="grid gap-4 md:grid-cols-3">
    {profile.languages.map((language, index) => (
      <GlassCard tone={language.tone} delay={index * 70} class="p-6 text-center">
        <span class={`mx-auto mb-4 block h-3 w-3 rounded-full ${toneStyles[language.tone].orb} ${toneStyles[language.tone].glow}`}></span>
        <h3 class={`font-display text-2xl font-semibold ${toneStyles[language.tone].text}`}>{language.language}</h3>
        <p class="mt-4 text-sm uppercase tracking-[0.28em] text-ink-400">{language.detail}</p>
        {language.href ? (
          <a
            href={resolveAssetUrl(language.href)}
            class="mt-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm font-semibold text-ink-100 transition duration-300 hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/[0.08]"
            download={language.download ? '' : undefined}
          >
            <span class="size-4 shrink-0 text-current" set:html={language.download ? icons.download : icons.external}></span>
            <span>{language.linkLabel ?? 'Open link'}</span>
          </a>
        ) : null}
      </GlassCard>
    ))}
  </div>
</SectionShell>
