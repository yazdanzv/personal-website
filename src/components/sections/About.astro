---
import { profile } from '../../config/profile';
import { icons } from '../../lib/icons';
import GlassCard from '../ui/GlassCard.astro';
import SectionShell from '../ui/SectionShell.astro';
import { toneStyles } from '../../lib/tone';

const highlightTerms = [
  'Adversarial Machine Learning',
  'Privacy-Preserving Learning',
  'Large Language Models',
  'Natural Language Processing',
  'Information Retrieval',
  'Distributed Systems',
  'Trustworthy AI',
  'Software Engineering',
  'Machine Learning',
  'AI Security',
];

const highlightClass = 'rounded-full border border-cyan-400/20 bg-cyan-400/10 px-2 py-0.5 font-semibold text-cyan-200';

const escapeHtml = (value: string) =>
  value
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#39;');

const escapeRegExp = (value: string) => value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

const highlightText = (value: string) => {
  let output = escapeHtml(value);

  for (const term of [...highlightTerms].sort((a, b) => b.length - a.length)) {
    const pattern = new RegExp(escapeRegExp(term), 'g');
    output = output.replace(pattern, `<span class="${highlightClass}">${term}</span>`);
  }

  return output;
};

const cardIcons = {
  academic: icons.academic,
  engineering: icons.engineering,
  research: icons.research,
} as const;
---

<SectionShell
  id="about"
  eyebrow="ABOUT"
  title={profile.about.title}
  description={profile.about.subtitle}
  tone="violet"
  titleClass="max-w-4xl font-display text-4xl font-semibold tracking-[-0.04em] text-ink-100 md:text-6xl xl:text-7xl"
  descriptionClass="mt-6 max-w-3xl text-base leading-8 text-ink-300 md:text-lg xl:text-xl"
>
  <div class="grid gap-6">
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {profile.about.metrics.map((metric, index) => (
        <div
          class="group relative overflow-hidden rounded-3xl border border-white/10 bg-white/[0.04] p-5 shadow-[0_20px_60px_rgba(0,0,0,0.22)] backdrop-blur-xl transition duration-300 hover:-translate-y-1 hover:border-white/20 hover:bg-white/[0.08]"
          data-reveal
          style={`--reveal-delay:${80 + index * 70}ms`}
        >
          <div
            aria-hidden="true"
            class={`pointer-events-none absolute inset-0 bg-gradient-to-br ${toneStyles[metric.tone].line} opacity-0 blur-2xl transition duration-300 group-hover:opacity-100`}
          ></div>
          <div class="relative z-10 flex items-start gap-4">
            <span class={`mt-1 h-3 w-3 rounded-full ${toneStyles[metric.tone].orb} ${toneStyles[metric.tone].glow}`}></span>
            <div>
              <p
                class={`font-display text-2xl font-semibold tracking-[-0.03em] ${toneStyles[metric.tone].text} md:text-3xl`}
              >
                {metric.value}
              </p>
              <p class="mt-2 text-xs uppercase tracking-[0.28em] text-ink-400">
                {metric.label}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <GlassCard class="p-7 md:p-9 xl:p-10" tone="violet" delay={80}>
      <div class="grid gap-8 lg:grid-cols-[1.14fr_0.86fr] lg:gap-10">
        <div class="space-y-6">
          {profile.about.paragraphs.map((paragraph, index) => (
            <p
              class="max-w-4xl text-base leading-8 text-ink-200 md:text-lg"
              data-reveal
              style={`--reveal-delay:${120 + index * 90}ms`}
              set:html={highlightText(paragraph)}
            ></p>
          ))}
        </div>

        <div class="grid gap-4">
          {profile.about.cards.map((card, index) => (
            <div
              class="group rounded-2xl border border-white/10 bg-surface-850/80 p-5 transition duration-300 hover:-translate-y-1 hover:border-white/20 hover:bg-surface-850"
              data-reveal
              style={`--reveal-delay:${170 + index * 90}ms`}
            >
              <div class="flex items-start gap-4">
                <div class={`flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.04] text-current transition duration-300 group-hover:scale-105 group-hover:border-white/20 ${toneStyles[card.tone].text} ${toneStyles[card.tone].glow}`}>
                  <span class="size-5" set:html={cardIcons[card.icon]}></span>
                </div>
                <div>
                  <div class="flex items-center gap-2">
                    <span class={`h-2.5 w-2.5 rounded-full ${toneStyles[card.tone].orb} ${toneStyles[card.tone].glow}`}></span>
                    <h3 class={`font-semibold ${toneStyles[card.tone].text}`}>{card.title}</h3>
                  </div>
                  <p class="mt-3 text-sm leading-7 text-ink-300 md:text-[0.95rem]" set:html={highlightText(card.description)}></p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </GlassCard>
  </div>
</SectionShell>
