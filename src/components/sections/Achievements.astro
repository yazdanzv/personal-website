---
import { profile } from '../../config/profile';
import SectionShell from '../ui/SectionShell.astro';
import GlassCard from '../ui/GlassCard.astro';
import { icons } from '../../lib/icons';
import { toneStyles } from '../../lib/tone';

const resolveAssetUrl = (href: string) => (href.startsWith('http') ? href : `${import.meta.env.BASE_URL ?? '/'}${href.replace(/^\/+/, '')}`);
---

<SectionShell
  id="achievements"
  eyebrow="ACHIEVEMENTS"
  title="Milestones Along the Way"
  description="Selected accomplishments that reflect years of learning, research, engineering, and continuous growth."
  tone="amber"
>
  <GlassCard tone={profile.achievements[0].tone} delay={40} class="p-6 md:p-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.32em] text-ink-400">Award</p>
        <h3 class={`mt-3 font-display text-2xl font-semibold ${toneStyles[profile.achievements[0].tone].text}`}>
          {profile.achievements[0].title}
        </h3>
        <p class="mt-4 text-base leading-8 text-ink-300">{profile.achievements[0].detail}</p>
        {profile.achievements[0].href ? (
          <a
            href={resolveAssetUrl(profile.achievements[0].href)}
            class="mt-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm font-semibold text-ink-100 transition duration-300 hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/[0.08]"
            download={profile.achievements[0].download ? '' : undefined}
          >
            <span class="size-4 shrink-0 text-current" set:html={profile.achievements[0].download ? icons.download : icons.external}></span>
            <span>{profile.achievements[0].linkLabel ?? 'Open link'}</span>
          </a>
        ) : null}
      </div>
      <div class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-xs font-semibold uppercase tracking-[0.3em] text-ink-300">
        {profile.achievements[0].year}
      </div>
    </div>
  </GlassCard>
</SectionShell>
