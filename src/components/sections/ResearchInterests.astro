---
import { profile } from '../../config/profile';
import GlassCard from '../ui/GlassCard.astro';
import SectionShell from '../ui/SectionShell.astro';
import { toneStyles } from '../../lib/tone';

---

<SectionShell
  id="research-interests"
  eyebrow="RESEARCH INTERESTS"
  title="Where My Curiosity Leads"
  description="From intelligent retrieval systems to trustworthy AI and scalable software architectures."
  tone="cyan"
>
  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {profile.researchInterests.map((interest, index) => (
      <GlassCard tone={interest.tone} delay={index * 70} class="h-full p-6">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-xs uppercase tracking-[0.32em] text-ink-400">Interest</p>
            <h3 class={`mt-3 font-display text-2xl font-semibold ${toneStyles[interest.tone].text}`}>
              {interest.title}
            </h3>
          </div>
          <span class={`mt-1 h-3 w-3 rounded-full ${toneStyles[interest.tone].orb} ${toneStyles[interest.tone].glow}`}></span>
        </div>
        <p class="mt-5 text-sm leading-7 text-ink-300">{interest.description}</p>
      </GlassCard>
    ))}
  </div>
</SectionShell>
