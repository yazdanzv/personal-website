---
import { profile } from '../../config/profile';
import SectionShell from '../ui/SectionShell.astro';
import GlassCard from '../ui/GlassCard.astro';
import SocialLink from '../ui/SocialLink.astro';
import { icons } from '../../lib/icons';
---

<SectionShell
  id="contact"
  eyebrow="Contact"
  title="Get in touch"
  description="For research, engineering, or collaboration opportunities, these are the easiest ways to reach me."
  tone="emerald"
>
  <GlassCard tone="emerald" delay={40} class="p-8 md:p-10">
    <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:gap-10">
      <div class="max-w-2xl">
        <h3 class="font-display text-3xl font-semibold text-ink-100 md:text-4xl">Let&apos;s talk directly</h3>
        <p class="mt-4 text-lg leading-8 text-ink-200 md:text-xl">
          {profile.contact.summary}
        </p>
      </div>

      <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 shadow-[0_20px_60px_rgba(0,0,0,0.22)] backdrop-blur-xl">
        <p class="text-xs uppercase tracking-[0.3em] text-ink-400">Profiles</p>
        <div class="mt-4 grid gap-3">
          {profile.contact.socials.map((social) =>
            social.icon === 'mail' ? (
              <button
                id="contact-copy-email"
                type="button"
                class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm font-medium text-ink-200 transition duration-300 hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/[0.08] hover:text-white"
                data-copy-text={profile.email}
                aria-label={`Copy ${profile.email} to clipboard`}
              >
                <span class="size-4 shrink-0 text-current" set:html={icons.mail}></span>
                <span>{profile.email}</span>
              </button>
            ) : (
              <SocialLink href={social.href} label={social.label} icon={social.icon} />
            ),
          )}
        </div>

        <p
          id="contact-copy-toast"
          class="pointer-events-none mt-4 inline-flex items-center gap-2 rounded-full border border-emerald-400/20 bg-emerald-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.26em] text-emerald-200 opacity-0 transition duration-300"
          aria-live="polite"
          aria-atomic="true"
        >
          <span class="size-3 rounded-full bg-emerald-300 shadow-[0_0_20px_rgba(52,211,153,0.35)]"></span>
          Email copied
        </p>
      </div>
    </div>
  </GlassCard>

  <script>
    const button = document.getElementById('contact-copy-email');
    const toast = document.getElementById('contact-copy-toast');
    let toastTimer;

    const showToast = () => {
      if (!toast) return;

      toast.classList.remove('opacity-0', 'translate-y-1');
      toast.classList.add('opacity-100', 'translate-y-0');

      window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => {
        toast.classList.add('opacity-0', 'translate-y-1');
        toast.classList.remove('opacity-100', 'translate-y-0');
      }, 1800);
    };

    if (button) {
      button.addEventListener('click', async () => {
        const email = button.getAttribute('data-copy-text');
        if (!email) return;

        try {
          await navigator.clipboard.writeText(email);
          showToast();
        } catch {
          showToast();
        }
      });
    }
  </script>
</SectionShell>
