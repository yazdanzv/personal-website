---
import { profile } from '../../config/profile';
import SectionShell from '../ui/SectionShell.astro';
import TimelineItem from '../ui/TimelineItem.astro';

---

<SectionShell
  id="experience"
  eyebrow="EXPERIENCE"
  title="The Journey So Far"
  description="Experiences in industry and research that shaped how I think about software, AI, and real-world impact."
  tone="emerald"
>
  <div class="grid gap-6">
    {profile.experience.map((entry, index) => (
      <TimelineItem entry={entry} delay={index * 80} />
    ))}
  </div>
</SectionShell>
